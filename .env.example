# ─────────────────────────────────────────────
# Gaboom Central — Variables d'environnement
# ─────────────────────────────────────────────

# Django
DEBUG=1
SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=centralborlette.settings

# Database (PostgreSQL en Docker, SQLite en dev local)
DATABASE_URL=postgres://gaboom:gaboom_secret@localhost:5432/centralborlette

# Redis (cache + channels + pont Gateway)
REDIS_URL=redis://localhost:6379/0

# Services externes (futurs)
VALIDATOR_ADDR=localhost:50051
GATEWAY_ADDR=:8080
